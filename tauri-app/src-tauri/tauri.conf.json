{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Configonaut",
  "version": "0.2.6",
  "identifier": "com.configonaut.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Configonaut",
        "width": 1200,
        "height": 780,
        "minWidth": 980,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      },
      {
        "label": "splash",
        "url": "splash.html",
        "title": "Configonaut",
        "width": 580,
        "height": 580,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwQkMxNUE0NjEzNUFFOEUKUldTT3JqVmhwQlc4VU9vYlhYUWF5VmRPZUExdnptSWcxRVBnc3hwWHdaSEc3SG81REdPM1JUenUK",
      "endpoints": [
        "https://github.com/aaronjellis/Configonaut/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "category": "DeveloperTool",
    "shortDescription": "Manage MCP servers, hooks, agents, and skills for Claude Desktop and Claude Code.",
    "longDescription": "Configonaut is a control panel for the Model Context Protocol (MCP) ecosystem. Browse and install servers from a curated marketplace, toggle them on and off without editing JSON by hand, manage hooks and skills, and keep timestamped backups of every config change.",
    "copyright": "Copyright \u00a9 2026 aaronjellis",
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
